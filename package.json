{
  "name": "ivo-desktop",
  "version": "0.1.0",
  "description": "IVO - Intelligent Voice Over Desktop App",
  "main": "dist-electron/main.js",
  "scripts": {
    "dev": "concurrently \"pnpm:dev:frontend\" \"pnpm:dev:electron\"",
    "dev:frontend": "vite",
    "dev:electron": "wait-on http://localhost:5173 && cross-env VITE_DEV_SERVER_URL=http://localhost:5173 electron .",
    "build": "vue-tsc --noEmit && vite build",
    "preview": "vite preview",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "vue-tsc --noEmit",
    "build:python": "uv run pyinstaller scripts/build-python.spec --noconfirm --distpath dist/python --workpath dist/python-build",
    "build:frontend": "pnpm run build",
    "build:all": "pnpm run build:frontend && pnpm run build:python && electron-builder",
    "build:win": "pnpm run build:all -- --win",
    "build:mac": "pnpm run build:all -- --mac",
    "build:linux": "pnpm run build:all -- --linux"
  },
  "dependencies": {
    "axios": "^1.7.0",
    "naive-ui": "^2.38.0",
    "pinia": "^2.2.0",
    "vue": "^3.5.0",
    "vue-router": "^4.4.0"
  },
  "devDependencies": {
    "@types/node": "^20.14.0",
    "@vitejs/plugin-vue": "^5.1.0",
    "concurrently": "^8.2.0",
    "cross-env": "^7.0.3",
    "electron": "^31.0.0",
    "electron-builder": "^24.13.0",
    "rcedit": "^5.0.2",
    "typescript": "^5.5.0",
    "vite": "^5.4.0",
    "vite-plugin-electron": "^0.28.0",
    "vitest": "^2.0.0",
    "vue-tsc": "^2.0.0",
    "wait-on": "^7.2.0"
  }
}
